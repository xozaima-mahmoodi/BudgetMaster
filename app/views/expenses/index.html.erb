<% content_for :title, "Expenses" %>

<div class="max-w-5xl mx-auto px-4 py-10">

  <%# Flash notice %>
  <% if notice.present? %>
    <p class="py-2 px-4 bg-green-50 mb-6 text-green-600 font-medium rounded-lg border border-green-200" id="notice"><%= notice %></p>
  <% end %>

  <%# Page header %>
  <div class="flex justify-between items-center mb-8">
    <div>
      <h1 class="font-bold text-3xl text-gray-900">BudgetMaster</h1>
      <p class="text-gray-400 text-sm mt-1">Track and manage your expenses</p>
    </div>
    <%= link_to "+ New Expense", new_expense_path, class: "rounded-lg px-4 py-2.5 bg-blue-600 hover:bg-blue-500 transition-colors text-white font-semibold text-sm shadow-sm" %>
  </div>

  <%# Summary cards %>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-8">

    <%# Total Lifetime card %>
    <div class="bg-gradient-to-br from-blue-600 to-indigo-700 rounded-2xl p-7 shadow-xl text-white">
      <p class="text-blue-200 text-xs font-semibold uppercase tracking-widest mb-3">Total Lifetime</p>
      <p class="text-5xl font-extrabold tracking-tight"><%= number_to_currency(@total_amount) %></p>
      <div class="mt-4">
        <span class="bg-white/20 text-white text-xs font-medium px-3 py-1 rounded-full">
          <%= pluralize(@expenses.size, "expense") %> recorded
        </span>
      </div>
    </div>

    <%# Current Month card %>
    <div class="bg-gradient-to-br from-emerald-500 to-green-700 rounded-2xl p-7 shadow-xl text-white">
      <p class="text-green-200 text-xs font-semibold uppercase tracking-widest mb-3">Current Month</p>
      <p class="text-5xl font-extrabold tracking-tight"><%= number_to_currency(@monthly_total) %></p>
      <div class="mt-4">
        <span class="bg-white/20 text-white text-xs font-medium px-3 py-1 rounded-full">
          <%= Date.current.strftime("%B %Y") %>
        </span>
      </div>
    </div>

  </div>

  <%# Expenses table %>
  <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="flex justify-between items-center px-6 py-4 border-b border-gray-100">
      <h2 class="font-semibold text-gray-700 text-lg">All Expenses</h2>
    </div>

    <% if @expenses.any? %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-100" id="expenses">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Title</th>
              <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Category</th>
              <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Date</th>
              <th class="px-6 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">Amount</th>
              <th class="px-6 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-50">
            <% @expenses.each do |expense| %>
              <tr class="hover:bg-gray-50 transition-colors">
                <%# Title %>
                <td class="px-6 py-4">
                  <p class="font-semibold text-gray-800"><%= expense.title %></p>
                </td>

                <%# Category badge %>
                <td class="px-6 py-4">
                  <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold <%= category_color_class(expense.category) %>">
                    <span class="font-bold"><%= expense.category&.first&.upcase %></span>
                    <%= expense.category&.capitalize %>
                  </span>
                </td>

                <%# Date %>
                <td class="px-6 py-4 text-sm text-gray-500">
                  <%= expense.entry_date&.strftime("%b %d, %Y") %>
                </td>

                <%# Amount %>
                <td class="px-6 py-4 text-right">
                  <span class="font-bold text-gray-800"><%= number_to_currency(expense.amount) %></span>
                </td>

                <%# Actions %>
                <td class="px-6 py-4 text-right">
                  <div class="flex justify-end items-center gap-3">
                    <%= link_to "Show", expense, class: "text-sm text-gray-400 hover:text-gray-600 font-medium" %>
                    <%= link_to "Edit", edit_expense_path(expense), class: "text-sm text-blue-500 hover:text-blue-700 font-medium" %>
                    <%= button_to "Delete", expense, method: :delete,
                          class: "text-sm text-red-400 hover:text-red-600 font-medium bg-transparent border-0 cursor-pointer p-0",
                          data: { turbo_confirm: "Delete this expense?" } %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="py-20 text-center text-gray-400">
        <p class="text-2xl mb-2">💸</p>
        <p class="text-lg font-medium">No expenses yet</p>
        <p class="text-sm mt-1">Click "+ New Expense" to get started.</p>
      </div>
    <% end %>
  </div>

</div>
