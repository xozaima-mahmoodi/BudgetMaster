<% content_for :title, "Expenses" %>

<div class="max-w-3xl mx-auto px-4 py-10">

  <%# Flash notice %>
  <% if notice.present? %>
    <p class="py-2 px-4 bg-green-50 mb-6 text-green-600 font-medium rounded-lg border border-green-200" id="notice"><%= notice %></p>
  <% end %>

  <%# Page header %>
  <div class="flex justify-between items-center mb-8">
    <h1 class="font-bold text-3xl text-gray-800">Expenses</h1>
    <%= link_to "+ New Expense", new_expense_path, class: "rounded-lg px-4 py-2.5 bg-blue-600 hover:bg-blue-500 transition-colors text-white font-medium text-sm shadow-sm" %>
  </div>

  <%# Total amount card %>
  <div class="bg-gradient-to-br from-blue-600 to-blue-800 rounded-2xl p-8 mb-8 shadow-lg text-white">
    <p class="text-blue-200 text-xs font-semibold uppercase tracking-widest mb-2">Total Spent</p>
    <p class="text-5xl font-bold tracking-tight"><%= number_to_currency(@total_amount) %></p>
    <p class="text-blue-200 text-sm mt-3"><%= pluralize(@expenses.size, "expense") %> recorded</p>
  </div>

  <%# Expense list %>
  <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-100">
      <h2 class="font-semibold text-gray-700">All Expenses</h2>
    </div>

    <div id="expenses">
      <% if @expenses.any? %>
        <% @expenses.each do |expense| %>
          <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center px-6 py-4 border-b border-gray-50 last:border-b-0 hover:bg-gray-50 transition-colors">

            <%# Left: avatar + info %>
            <div class="flex items-center gap-4 flex-1">
              <div class="w-10 h-10 rounded-full bg-blue-100 text-blue-600 flex items-center justify-center font-bold text-sm flex-shrink-0">
                <%= expense.category&.first&.upcase || "?" %>
              </div>
              <div>
                <p class="font-semibold text-gray-800"><%= expense.title %></p>
                <p class="text-sm text-gray-400">
                  <%= expense.category %> &middot; <%= expense.entry_date&.strftime("%b %d, %Y") %>
                </p>
              </div>
            </div>

            <%# Right: amount + actions %>
            <div class="flex items-center gap-4 mt-3 sm:mt-0">
              <span class="font-bold text-gray-800 text-lg"><%= number_to_currency(expense.amount) %></span>
              <%= link_to "Show", expense, class: "text-sm text-gray-400 hover:text-gray-600 font-medium" %>
              <%= link_to "Edit", edit_expense_path(expense), class: "text-sm text-blue-500 hover:text-blue-700 font-medium" %>
              <%= button_to "Delete", expense, method: :delete,
                    class: "text-sm text-red-400 hover:text-red-600 font-medium bg-transparent border-0 cursor-pointer p-0",
                    data: { turbo_confirm: "Delete this expense?" } %>
            </div>

          </div>
        <% end %>
      <% else %>
        <div class="py-16 text-center text-gray-400">
          <p class="text-lg font-medium">No expenses yet</p>
          <p class="text-sm mt-1">Add your first expense to get started.</p>
        </div>
      <% end %>
    </div>
  </div>

</div>
