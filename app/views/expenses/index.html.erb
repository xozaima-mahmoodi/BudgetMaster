<% content_for :title, "Expenses" %>

<div class="min-h-screen bg-slate-100 py-10 px-4">
  <div class="max-w-5xl mx-auto">

    <%# Flash notice %>
    <% if notice.present? %>
      <p class="py-2 px-4 bg-emerald-50 mb-6 text-emerald-700 font-medium rounded-lg border border-emerald-200" id="notice">
        <%= notice %>
      </p>
    <% end %>

    <%# Page header %>
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-8 gap-4">
      <div>
        <h1 class="font-extrabold text-3xl text-slate-800 tracking-tight">BudgetMaster</h1>
        <p class="text-slate-400 text-sm mt-1">Your personal finance dashboard</p>
      </div>
      <%= link_to new_expense_path,
            class: "inline-flex items-center gap-2 rounded-xl px-5 py-2.5 bg-blue-600 hover:bg-blue-500 active:bg-blue-700 transition-colors text-white font-semibold text-sm shadow-md" do %>
        <span class="text-lg leading-none">+</span> New Expense
      <% end %>
    </div>

    <%# Stats cards %>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-8">

      <%# Total Lifetime %>
      <div class="relative overflow-hidden bg-gradient-to-br from-blue-600 to-indigo-700 rounded-2xl p-7 shadow-lg text-white">
        <div class="absolute -top-6 -right-6 w-32 h-32 bg-white/10 rounded-full"></div>
        <div class="absolute -bottom-8 -right-2 w-24 h-24 bg-white/5 rounded-full"></div>
        <p class="text-blue-200 text-xs font-bold uppercase tracking-widest mb-3">Total Lifetime</p>
        <p class="text-5xl font-extrabold tracking-tight mb-4"><%= number_to_currency(@total_amount) %></p>
        <span class="inline-block bg-white/20 text-white text-xs font-semibold px-3 py-1.5 rounded-full">
          <%= pluralize(@expenses.size, "expense") %> recorded
        </span>
      </div>

      <%# This Month %>
      <div class="relative overflow-hidden bg-gradient-to-br from-emerald-500 to-teal-700 rounded-2xl p-7 shadow-lg text-white">
        <div class="absolute -top-6 -right-6 w-32 h-32 bg-white/10 rounded-full"></div>
        <div class="absolute -bottom-8 -right-2 w-24 h-24 bg-white/5 rounded-full"></div>
        <p class="text-emerald-200 text-xs font-bold uppercase tracking-widest mb-3">This Month</p>
        <p class="text-5xl font-extrabold tracking-tight mb-4"><%= number_to_currency(@monthly_total) %></p>
        <span class="inline-block bg-white/20 text-white text-xs font-semibold px-3 py-1.5 rounded-full">
          <%= Date.current.strftime("%B %Y") %>
        </span>
      </div>

    </div>

    <%# Expenses table card %>
    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">

      <div class="flex justify-between items-center px-6 py-4 border-b border-slate-100 bg-slate-50">
        <div>
          <h2 class="font-bold text-slate-700 text-lg">All Expenses</h2>
          <p class="text-slate-400 text-xs mt-0.5">Ordered by most recent date</p>
        </div>
      </div>

      <% if @expenses.any? %>
        <div class="overflow-x-auto" id="expenses">
          <table class="min-w-full">
            <thead>
              <tr class="border-b border-slate-100">
                <th class="px-6 py-3 text-left text-xs font-bold text-slate-400 uppercase tracking-wider">Title</th>
                <th class="px-6 py-3 text-left text-xs font-bold text-slate-400 uppercase tracking-wider">Category</th>
                <th class="px-6 py-3 text-left text-xs font-bold text-slate-400 uppercase tracking-wider">Date</th>
                <th class="px-6 py-3 text-right text-xs font-bold text-slate-400 uppercase tracking-wider">Amount</th>
                <th class="px-6 py-3 text-right text-xs font-bold text-slate-400 uppercase tracking-wider">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-50">
              <% @expenses.each do |expense| %>
                <tr class="hover:bg-slate-50 transition-colors group">

                  <%# Title %>
                  <td class="px-6 py-4">
                    <p class="font-semibold text-slate-800 group-hover:text-blue-600 transition-colors">
                      <%= expense.title %>
                    </p>
                  </td>

                  <%# Category badge %>
                  <td class="px-6 py-4">
                    <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-bold <%= category_color_class(expense.category) %>">
                      <%= expense.category&.capitalize %>
                    </span>
                  </td>

                  <%# Date %>
                  <td class="px-6 py-4">
                    <span class="text-sm text-slate-500"><%= expense.entry_date&.strftime("%b %d, %Y") %></span>
                  </td>

                  <%# Amount %>
                  <td class="px-6 py-4 text-right">
                    <span class="font-extrabold text-slate-800 tabular-nums">
                      <%= number_to_currency(expense.amount) %>
                    </span>
                  </td>

                  <%# Actions %>
                  <td class="px-6 py-4 text-right">
                    <div class="flex justify-end items-center gap-3 opacity-50 group-hover:opacity-100 transition-opacity">
                      <%= link_to "Show", expense,
                            class: "text-xs text-slate-500 hover:text-slate-700 font-semibold" %>
                      <%= link_to "Edit", edit_expense_path(expense),
                            class: "text-xs text-blue-500 hover:text-blue-700 font-semibold" %>
                      <%= button_to "Delete", expense, method: :delete,
                            class: "text-xs text-red-400 hover:text-red-600 font-semibold bg-transparent border-0 cursor-pointer p-0",
                            data: { turbo_confirm: "Delete this expense?" } %>
                    </div>
                  </td>

                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="py-20 text-center">
          <p class="text-4xl mb-3">💸</p>
          <p class="text-lg font-semibold text-slate-600">No expenses yet</p>
          <p class="text-sm text-slate-400 mt-1 mb-6">Start tracking your spending below.</p>
          <%= link_to "+ New Expense", new_expense_path,
                class: "inline-block rounded-xl px-5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white font-semibold text-sm shadow-md transition-colors" %>
        </div>
      <% end %>

    </div>

  </div>
</div>
